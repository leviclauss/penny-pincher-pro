# Copy to .env and fill in.

# --- Alpaca ---
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Set to "iex" for free-tier delayed feed; "sip" requires paid subscription.
ALPACA_DATA_FEED=iex
# Options feed: "indicative" (free, EOD-ish) or "opra" (paid, real-time).
ALPACA_OPTIONS_FEED=indicative

# Risk-free rate for Black-Scholes IV inversion fallback. Refresh quarterly
# from the 3-month T-bill (FRED: TB3MS).
RISK_FREE_RATE=0.045
# Don't fetch chains beyond this many days to expiration.
OPTIONS_MAX_DTE=60
# Only fetch strikes within ±this fraction of underlying spot.
OPTIONS_STRIKE_PCT_WINDOW=0.15

# --- Options provider ---
# "alpaca" (default, free indicative — no OI/volume) or "polygon" (paid,
# populates OI + volume so liquidity filters can fire). Selecting "polygon"
# without a POLYGON_API_KEY logs a warning and falls back to Alpaca.
OPTIONS_PROVIDER=alpaca

# --- Polygon (options data) ---
# Sign up at polygon.io. Options Developer tier (~$79/mo) gives realtime
# chains + multi-year history and is what unlocks the Phase 2 backtest
# work. Starter (~$29/mo, EOD-only) also works for the live snapshot.
POLYGON_API_KEY=
POLYGON_BASE_URL=https://api.polygon.io
# Defensive sliding-window cap inside PolygonClient. Polygon Developer is
# effectively unlimited; bump only if you observe 429s.
POLYGON_RATE_LIMIT_PER_MIN=100

# --- Polygon flat files (S3, historical backfill) ---
# Polygon publishes daily option aggregates at
# s3://flatfiles/us_options_opra/day_aggs_v1/. Credentials are issued
# separately from the REST API key — find them in the Polygon dashboard
# under "S3 Access Keys". Used by `python -m ingestion.options_history`
# (the default --source flatfile path). Requires the 'backup-s3' extra
# for boto3: `pip install -e .[backup-s3]`.
POLYGON_FLATFILES_ACCESS_KEY_ID=
POLYGON_FLATFILES_SECRET_ACCESS_KEY=
POLYGON_FLATFILES_S3_REGION=us-east-1

# --- Earnings (Finnhub) ---
# Free tier at finnhub.io: 60 calls/min, US equities calendar.
# Without a key, earnings ingestion is skipped (the rest of the pipeline runs).
FINNHUB_API_KEY=
FINNHUB_BASE_URL=https://finnhub.io/api/v1
EARNINGS_LOOKAHEAD_DAYS=90
# Sliding-window cap inside FinnhubClient (free tier ceiling is 60 cpm).
# See docs/ops/api-rate-limits.md.
FINNHUB_RATE_LIMIT_PER_MIN=55
# Bulk earnings calendar: 1 call/run + per-symbol fallback only for symbols
# entirely missing from bulk. OFF by default because Finnhub bulk silently
# drops some upcoming reports (observed with MSTR), which can land us with
# the wrong "next earnings" date. The rate limiter above already keeps
# per-symbol within budget, so the safer default is per-symbol everywhere.
FINNHUB_EARNINGS_USE_BULK=false

# --- Macro (Yahoo Finance, no auth) ---
YAHOO_BASE_URL=https://query1.finance.yahoo.com
MACRO_LOOKBACK_DAYS=365
SPY_SYMBOL=SPY

# --- Scheduler ---
# When false, FastAPI starts without APScheduler (useful for tests / one-off
# CLI runs). Schedule times are in TIMEZONE; defaults match doc 07
# (5:30 PM Pacific, after the 4 PM ET cash close + buffer).
SCHEDULER_ENABLED=true
SCHEDULER_EVENING_HOUR=17
SCHEDULER_EVENING_MINUTE=30
# Morning digest fires Mon-Fri before market open; evening digest fires
# after the position-management pass so today's screener hits + P&L are
# included.
SCHEDULER_MORNING_DIGEST_HOUR=8
SCHEDULER_MORNING_DIGEST_MINUTE=0
SCHEDULER_EVENING_DIGEST_HOUR=18
SCHEDULER_EVENING_DIGEST_MINUTE=30
# pandas_market_calendars name. Use NYSE for US equities. Set to "" to
# disable holiday skipping.
MARKET_CALENDAR=NYSE

# --- Intraday alert pulse (phase 3) ---
# Off by default — turn on once Telegram is configured and you trust the
# screener configs you have active. When enabled, runs every N minutes
# during RTH, fires `setup_triggered` when a watchlist symbol newly passes
# a config (suppressed if already in this morning's digest).
SCHEDULER_INTRADAY_ENABLED=false
SCHEDULER_INTRADAY_INTERVAL_MINUTES=15
INTRADAY_QUOTE_MAX_AGE_S=90
# IV-spike pass (intraday ATM IV vs the most recent daily iv_atm).
# Pulls option chains per symbol — burns Alpaca quota; default off and
# throttled to a slower cadence than the setup pass.
INTRADAY_IV_SPIKE_ENABLED=false
INTRADAY_IV_SPIKE_PCT=0.20
INTRADAY_IV_SPIKE_INTERVAL_MINUTES=30

# --- Database ---
# Leave commented to use the default (absolute path built by config.py).
# DATABASE_URL=sqlite:////absolute/path/to/data/wheel.db

# --- App ---
APP_ENV=dev
TIMEZONE=America/Los_Angeles
LOG_LEVEL=INFO
LOG_JSON=false

# --- Telegram (optional notification channel) ---
# Create a bot via @BotFather and DM it once to seed getUpdates.
# Without TELEGRAM_BOT_TOKEN the channel is unregistered and any
# alert_preferences entry containing "telegram" is treated as a no-op
# (logged at WARNING).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PARSE_MODE=MarkdownV2
TELEGRAM_DISABLE_PREVIEW=true

# --- Telegram inbound bot (phase 3-4: /status, /snooze, inline ack) ---
# Off by default — turn on once outbound is verified. When enabled, a
# single long-poll task runs alongside the scheduler, restricted to the
# allow-listed TELEGRAM_CHAT_ID. Updates from any other chat are dropped
# with a WARNING log. The poller persists its getUpdates offset in the
# bot_state table so restarts don't replay history.
TELEGRAM_INBOUND_ENABLED=false
TELEGRAM_INBOUND_LONG_POLL_S=25
TELEGRAM_INBOUND_HEARTBEAT_S=300

# --- Nightly SQLite backup ---
# Snapshot the live SQLite DB once per day via the SQLite online backup API
# (safe under WAL writes). Defaults: 03:00 in TIMEZONE, keep last 14 files
# under data/backups/. Relative BACKUP_DIR resolves next to the live DB.
BACKUP_DIR=data/backups
BACKUP_RETENTION=14
SCHEDULER_BACKUP_HOUR=3
SCHEDULER_BACKUP_MINUTE=0
# Off-site upload — disabled by default. Provider is "s3" (AWS) or "b2"
# (Backblaze, S3-compatible). Both go through the boto3 S3 client; install
# the optional extra once and the runtime picks it up: `pip install -e .[backup-s3]`.
# For B2, BACKUP_OFFSITE_ENDPOINT_URL is required (e.g.
# https://s3.us-west-002.backblazeb2.com); for AWS it's optional. Credentials
# fall back to the standard AWS env / instance metadata if left blank.
BACKUP_OFFSITE_ENABLED=false
BACKUP_OFFSITE_PROVIDER=
BACKUP_OFFSITE_BUCKET=
BACKUP_OFFSITE_PREFIX=
BACKUP_OFFSITE_ENDPOINT_URL=
BACKUP_OFFSITE_REGION=
BACKUP_OFFSITE_ACCESS_KEY_ID=
BACKUP_OFFSITE_SECRET_ACCESS_KEY=

# --- Healthchecks.io heartbeat ---
# Per-job ping URL is read from HEALTHCHECKS_URL_<JOB_NAME> (uppercase),
# e.g. HEALTHCHECKS_URL_EVENING_PIPELINE=https://hc-ping.com/<uuid>. Each
# scheduled job pings /start on entry, the bare URL on success, and /fail
# on exception. Missing per-job URLs short-circuit silently. Flip the
# master switch off to disable the feature without unsetting URLs.
HEALTHCHECKS_ENABLED=true
HEALTHCHECKS_TIMEOUT_S=5
# HEALTHCHECKS_URL_EVENING_PIPELINE=
# HEALTHCHECKS_URL_SCREENER=
# HEALTHCHECKS_URL_POSITION_MANAGEMENT=
# HEALTHCHECKS_URL_MORNING_DIGEST=
# HEALTHCHECKS_URL_EVENING_DIGEST=
# HEALTHCHECKS_URL_SQLITE_BACKUP=

# --- Email (SMTP, optional notification channel) ---
# Without SMTP_HOST + SMTP_FROM_ADDRESS + SMTP_TO_ADDRESS the email channel
# is unregistered and any alert_preferences entry containing "email" logs a
# WARNING and is treated as a no-op.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Use STARTTLS on a submission port (587). Set SMTP_USE_SSL=true (and port
# 465) for implicit TLS. Both default off if SMTP_HOST is unset anyway.
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM_ADDRESS=
SMTP_TO_ADDRESS=
SMTP_TIMEOUT_S=10

# --- ntfy.sh (optional push channel) ---
# Default server is the public ntfy.sh; point at a self-hosted instance via
# NTFY_SERVER_URL. Without NTFY_TOPIC the channel is a no-op (logged at
# WARNING). NTFY_TOKEN is optional — only needed for ACL-protected topics.
NTFY_SERVER_URL=https://ntfy.sh
NTFY_TOPIC=
NTFY_TOKEN=
# One of: min, low, default, high, urgent (ntfy priority headers).
NTFY_PRIORITY=default
NTFY_TIMEOUT_S=10

# --- Web UI deep links (optional) ---
# When set, alert templates append "Open" links to the local web UI for
# tickers, screener configs, and positions. Use the Tailscale hostname for
# remote access from your phone (e.g. https://wheel.tail-scale.ts.net).
# No trailing slash. Leave blank to disable links.
WEB_BASE_URL=

# --- (future sessions) ---
# APP_USERNAME=
# APP_PASSWORD_HASH=
